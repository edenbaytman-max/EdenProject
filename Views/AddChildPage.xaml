<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:EdenProject.ViewModels"
             x:Class="EdenProject.Views.AddChildPage"
             x:DataType="viewmodels:AddChildViewModel"
             Title="הוספת ילד חדש">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        <Label Text="הוספת ילד למערכת" 
               FontSize="24" 
               HorizontalOptions="Center" 
               TextColor="MediumPurple" 
               FontAttributes="Bold"/>

        <Entry Placeholder="שם הילד/ה" 
               Text="{Binding Name}" 
               FontSize="18" />

        <Entry Placeholder="גיל הילד/ה" 
               Text="{Binding Age}" 
               Keyboard="Numeric" 
               FontSize="18" />

        <Button Text="שמור והמשך" 
                Command="{Binding SaveChildCommand}"
                BackgroundColor="MediumPurple"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"
                Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>