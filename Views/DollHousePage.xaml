<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EdenProject.ViewModels"
             x:Class="EdenProject.Views.DollHousePage"
             Title="בית הבובות של {Binding ChildName}"
             ControlTemplate="{StaticResource BasePageTemplate}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="10" RowSpacing="10" BackgroundColor="#FDFBF7">

        <Label Grid.Row="0" Text="{Binding GameStatusMessage}" 
               FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#5A5A5A"/>

        <Grid Grid.Row="1" ColumnDefinitions="140, *" ColumnSpacing="10">

            <ScrollView Grid.Column="0">
                <VerticalStackLayout Spacing="15">

                    <Label Text="👥 דמויות:" FontAttributes="Bold" TextColor="#5A5A5A" HorizontalOptions="Center"/>
                    <Frame BackgroundColor="#FFF3E0" CornerRadius="10" Padding="5" BorderColor="#FFE0B2" HasShadow="False">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🧑 הילד" FontSize="18">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:הילד" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="👩 אמא" FontSize="18">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:אמא" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="👨 אבא" FontSize="18">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:אבא" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="👧 אחות" FontSize="18">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:אחות" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="👦 אח" FontSize="18">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:אח" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="🐶 כלב" FontSize="18">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:כלב" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="🦁 אריה" FontSize="18" TextColor="Red">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:אריה" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="🦈 כריש" FontSize="18" TextColor="Red">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Character:כריש" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>

                    <Label Text="🎭 רגשות:" FontAttributes="Bold" TextColor="#5A5A5A" HorizontalOptions="Center"/>
                    <Frame BackgroundColor="#E1F5FE" CornerRadius="10" Padding="5" BorderColor="#B3E5FC" HasShadow="False">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="😃 שמחה" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:😃 שמחה" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="😢 עצב" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:😢 עצב" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="😡 כעס" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:😡 כעס" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="😨 פחד" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:😨 פחד" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="🥰 אהבה" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:🥰 אהבה" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="💚 קנאה" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:💚 קנאה" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="😌 רוגע" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:😌 רוגע" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="⛈️ סערה" FontSize="16">
                                <Label.GestureRecognizers>
                                    <DragGestureRecognizer CanDrag="True" DragStartingCommandParameter="Emotion:⛈️ סערה" DragStarting="DragGestureRecognizer_DragStarting"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Column="1" RowDefinitions="*, *, 100" ColumnDefinitions="*, *" RowSpacing="8" ColumnSpacing="8">

                <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="#E8EAF6" BorderColor="#C5CAE9" Padding="5">
                    <StackLayout>
                        <Label Text="🏠 חדר הורים" FontAttributes="Bold" HorizontalOptions="Center" FontSize="12"/>
                        <CollectionView ItemsSource="{Binding ParentsRoomItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding}" FontSize="14" HorizontalOptions="Center"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True" AutomationId="חדר הורים" Drop="DropGestureRecognizer_Drop"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="#E3F2FD" BorderColor="#BBDEFB" Padding="5">
                    <StackLayout>
                        <Label Text="🧸 חדר הילד" FontAttributes="Bold" HorizontalOptions="Center" FontSize="12"/>
                        <CollectionView ItemsSource="{Binding ChildsRoomItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding}" FontSize="14" HorizontalOptions="Center"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True" AutomationId="חדר ילד" Drop="DropGestureRecognizer_Drop"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="#FFFDE7" BorderColor="#FFF9C4" Padding="5">
                    <StackLayout>
                        <Label Text="🍳 מטבח" FontAttributes="Bold" HorizontalOptions="Center" FontSize="12"/>
                        <CollectionView ItemsSource="{Binding KitchenItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding}" FontSize="14" HorizontalOptions="Center"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True" AutomationId="מטבח" Drop="DropGestureRecognizer_Drop"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="#E8F5E9" BorderColor="#C8E6C9" Padding="5">
                    <StackLayout>
                        <Label Text="🛋️ סלון" FontAttributes="Bold" HorizontalOptions="Center" FontSize="12"/>
                        <CollectionView ItemsSource="{Binding LivingRoomItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding}" FontSize="14" HorizontalOptions="Center"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True" AutomationId="סלון" Drop="DropGestureRecognizer_Drop"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="#F1F8E9" BorderColor="#DCEDC8" Padding="5">
                    <StackLayout>
                        <Label Text="🌳 גינה" FontAttributes="Bold" HorizontalOptions="Center" FontSize="12"/>
                        <CollectionView ItemsSource="{Binding GardenItems}" ItemsLayout="HorizontalList">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding}" FontSize="14" Margin="5"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True" AutomationId="גינה" Drop="DropGestureRecognizer_Drop"/>
                    </Frame.GestureRecognizers>
                </Frame>

            </Grid>
        </Grid>

        <Button Grid.Row="2" Text="הפק ניתוח AI 🌟" Command="{Binding EndGameCommand}" 
                BackgroundColor="#FF8A65" TextColor="White" FontAttributes="Bold" HeightRequest="45"/>
    </Grid>
</ContentPage>