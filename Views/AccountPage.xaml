<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:EdenProject.ViewModels"
             x:Class="EdenProject.Views.AccountPage"
             x:DataType="viewmodels:AccountPageViewModel"
             Title="My Account">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Start">

            <Frame HeightRequest="100" 
                   WidthRequest="100" 
                   CornerRadius="50" 
                   HorizontalOptions="Center" 
                   BackgroundColor="MediumPurple"
                   Padding="0"
                   HasShadow="True">
                <Label Text="👤" FontSize="50" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Frame>

            <Label Text="Edit Profile" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="MediumPurple"/>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>

            <VerticalStackLayout Spacing="10">
                <Label Text="First Name" FontAttributes="Bold" Margin="5,0"/>
                <Entry Text="{Binding SelectedUser.FirstName}" 
                       Placeholder="Enter first name"
                       BackgroundColor="#F0F0F0"/>

                <Label Text="Last Name" FontAttributes="Bold" Margin="5,0"/>
                <Entry Text="{Binding SelectedUser.LastName}" 
                       Placeholder="Enter last name"
                       BackgroundColor="#F0F0F0"/>

                <Label Text="Email (Cannot be changed)" FontAttributes="Bold" Margin="5,0" TextColor="Gray"/>
                <Entry Text="{Binding SelectedUser.UserEmail}" 
                       IsEnabled="False" 
                       TextColor="Gray"
                       BackgroundColor="#E8E8E8"/>

                <Label Text="Password" FontAttributes="Bold" Margin="5,0"/>
                <Entry Text="{Binding SelectedUser.UserPassword}" 
                       IsPassword="True" 
                       Placeholder="Enter password"
                       BackgroundColor="#F0F0F0"/>

                <Label Text="Mobile" FontAttributes="Bold" Margin="5,0"/>
                <Entry Text="{Binding SelectedUser.UserMobile}" 
                       Placeholder="Enter mobile number"
                       BackgroundColor="#F0F0F0"
                       Keyboard="Telephone"/>
            </VerticalStackLayout>

            <Button Text="Save Changes" 
                    Command="{Binding SaveChangesCommand}"
                    BackgroundColor="MediumPurple"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontAttributes="Bold"
                    Margin="0,20,0,0"/>

            <Button Text="Cancel" 
                    Command="{Binding NavigateBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="Gray"
                    FontSize="14"
                    HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>