<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:EdenProject.ViewModels"
             x:Class="EdenProject.Views.ParentVerificationPage"
             Title="אימות הורה"
             NavigationPage.HasBackButton="False"
             FlowDirection="RightToLeft"
             BackgroundColor="#F4F6FA">

    <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">

        <ScrollView VerticalOptions="Center" HorizontalOptions="Center">
            <VerticalStackLayout Spacing="25" Padding="30" WidthRequest="400" VerticalOptions="Center">

                <Label Text="🔒" 
                       FontSize="60" 
                       HorizontalOptions="Center" />

                <Label Text="כניסה לאזור הורים" 
                       FontSize="26" 
                       FontAttributes="Bold" 
                       TextColor="#333333"
                       HorizontalOptions="Center" />

                <Label Text="על מנת לצפות בניתוח המשחק הפסיכולוגי של הילד, אנא הזן את סיסמת ההורה שלך לאבטחת המידע." 
                       FontSize="15" 
                       TextColor="#666666"
                       HorizontalTextAlignment="Center" 
                       HorizontalOptions="Center" />

                <Frame CornerRadius="10" Padding="0" HasShadow="False" BorderColor="#DDDDDD" BackgroundColor="White">
                    <Entry Text="{Binding PasswordInput}" 
                           IsPassword="True" 
                           Placeholder="הזן סיסמת הורה כאן" 
                           FontSize="18"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center"
                           HeightRequest="55" />
                </Frame>

                <Label Text="{Binding ErrorMessage}" 
                       TextColor="Red" 
                       FontSize="14"
                       HorizontalOptions="Center"
                       IsVisible="{Binding IsErrorVisible}" />

                <VerticalStackLayout Spacing="12" Margin="0,10,0,0">
                    <Button Text="אמת סיסמה והפק ניתוח 🌟" 
                            Command="{Binding VerifyPasswordCommand}"
                            BackgroundColor="#512BD4" 
                            TextColor="White" 
                            FontAttributes="Bold"
                            HeightRequest="50" 
                            CornerRadius="10" />

                    <Button Text="חזרה למשחק בית הבובות 🏡" 
                            Command="{Binding CancelCommand}"
                            BackgroundColor="Transparent" 
                            TextColor="#512BD4" 
                            BorderColor="#512BD4"
                            BorderWidth="1"
                            HeightRequest="50" 
                            CornerRadius="10" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="#CC000000" 
              IsVisible="{Binding IsBusy}" 
              HorizontalOptions="FillAndExpand" 
              VerticalOptions="FillAndExpand">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" Scale="2" />
                <Label Text="ג'מיני AI מנתח כעת את מהלכי המשחק..." 
                       TextColor="White" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="ברוח תיאוריית יחסי האובייקט של מלאני קליין" 
                       TextColor="#CCCCCC" 
                       FontSize="14" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>